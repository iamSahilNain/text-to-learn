# --- Required ---

# MongoDB connection string (Atlas or local).
# Example (Atlas): mongodb+srv://USER:PASSWORD@cluster.xxxxx.mongodb.net/text-to-learn
MONGO_URI=

# Google Gemini API key — used to generate course outlines and lesson content.
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- Optional ---

# Gemini model id. Defaults to gemini-2.5-flash if unset.
# Change this if your key doesn't have access to the default model.
GEMINI_MODEL=gemini-2.5-flash

# YouTube Data API v3 key — used to attach related videos to lessons.
# OPTIONAL: if left blank, lessons are generated without videos (no errors).
# Get one at https://console.cloud.google.com (enable "YouTube Data API v3").
YOUTUBE_API_KEY=

# Port the API server listens on. Defaults to 3001 if unset.
PORT=3001
